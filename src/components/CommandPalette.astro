---
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const navItems = [
	{ title: 'Home', href: withBase('') },
	{ title: 'Work', href: withBase('work') },
	{ title: 'About', href: withBase('about') },
	{ title: 'Contact', href: withBase('contact') },
];

const personalItems = [
	{ title: 'Recipes', href: withBase('recipes') },
	{ title: 'Photos', href: withBase('photos') },
	{ title: 'Now', href: withBase('now') },
];

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const workItems = work.map((project) => ({
	title: project.data.name,
	href: withBase(`work/${project.id}`),
	search: [project.data.name, project.data.title, project.data.subtitle, (project.data.tags ?? []).join(' '), project.data.metric, project.data.metricLabel]
		.join(' ')
		.toLowerCase(),
}));

const actionItems = [
	{ title: 'Toggle theme', action: 'toggle-theme' },
	{ title: 'View Resume', href: withBase('resume.pdf') },
];

const groups = [
	{ label: 'Navigation', items: navItems },
	{ label: 'Case Studies', items: workItems },
	{ label: 'Personal', items: personalItems },
	{ label: 'Actions', items: actionItems },
];
---

<div class="command-palette-overlay" id="command-palette-overlay">
	<div class="command-palette" role="dialog" aria-modal="true" aria-label="Command palette">
		<input
			type="text"
			class="command-palette-input"
			id="command-palette-input"
			placeholder="Jump to a page, case study, or action…"
			aria-label="Search"
			aria-controls="command-palette-list"
			aria-autocomplete="list"
			autocomplete="off"
		/>
		<ul class="command-palette-list" id="command-palette-list" role="listbox">
			{groups.map((group, gi) => (
				<>
					<li class="command-palette-group-label" data-group={`group-${gi}`}>{group.label}</li>
					{group.items.map((item, i) => (
						<li
							class="command-palette-item"
							id={`command-palette-item-${gi}-${i}`}
							role="option"
							aria-selected="false"
							data-group={`group-${gi}`}
							data-href={'href' in item ? item.href : undefined}
							data-action={'action' in item ? item.action : undefined}
							data-search={'search' in item ? item.search : item.title.toLowerCase()}
						>
							{item.title}
						</li>
					))}
				</>
			))}
		</ul>
		<p class="command-palette-empty" hidden>No matches</p>
		<div class="command-palette-hint">
			<span><kbd>&uarr;</kbd><kbd>&darr;</kbd> navigate</span>
			<span><kbd>&crarr;</kbd> select</span>
			<span><kbd>esc</kbd> close</span>
		</div>
	</div>
</div>

<script>
	import { navigate } from 'astro:transitions/client';

	let activeIndex = 0;
	let lastFocused: Element | null = null;

	function overlay() {
		return document.getElementById('command-palette-overlay');
	}

	function input() {
		return document.getElementById('command-palette-input') as HTMLInputElement | null;
	}

	function allItems() {
		return Array.from(document.querySelectorAll<HTMLLIElement>('.command-palette-item'));
	}

	function allGroupLabels() {
		return Array.from(document.querySelectorAll<HTMLLIElement>('.command-palette-group-label'));
	}

	function visibleItems() {
		return allItems().filter((item) => !item.hidden);
	}

	function isOpen() {
		return overlay()?.classList.contains('open') ?? false;
	}

	function highlight(index: number) {
		const visible = visibleItems();
		if (visible.length === 0) return;
		activeIndex = (index + visible.length) % visible.length;
		visible.forEach((item, i) => {
			const active = i === activeIndex;
			item.classList.toggle('is-active', active);
			item.setAttribute('aria-selected', String(active));
		});
		const activeItem = visible[activeIndex];
		activeItem.scrollIntoView({ block: 'nearest' });
		input()?.setAttribute('aria-activedescendant', activeItem.id);
	}

	function filter(query: string) {
		const q = query.trim().toLowerCase();
		allItems().forEach((item) => {
			item.hidden = q.length > 0 && !item.dataset.search?.includes(q);
		});
		allGroupLabels().forEach((label) => {
			const group = label.dataset.group;
			const hasVisible = allItems().some((item) => item.dataset.group === group && !item.hidden);
			label.hidden = !hasVisible;
		});
		const empty = document.querySelector('.command-palette-empty');
		if (empty) (empty as HTMLElement).hidden = visibleItems().length > 0;
		highlight(0);
	}

	function open() {
		const ov = overlay();
		if (!ov) return;
		lastFocused = document.activeElement;
		ov.classList.add('open');
		const field = input();
		if (field) {
			field.value = '';
			filter('');
			field.focus();
		}
	}

	function close() {
		overlay()?.classList.remove('open');
		if (lastFocused instanceof HTMLElement) lastFocused.focus();
	}

	function runAction(action: string) {
		if (action === 'toggle-theme') {
			document.querySelector('.theme-toggle')?.dispatchEvent(new MouseEvent('click', { bubbles: true }));
		}
	}

	function goTo(item: HTMLElement) {
		const href = item.dataset.href;
		const action = item.dataset.action;
		close();
		if (href) navigate(href);
		else if (action) runAction(action);
	}

	function onGlobalKeydown(e: KeyboardEvent) {
		if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
			e.preventDefault();
			isOpen() ? close() : open();
			return;
		}
		if (e.key === 'Escape' && isOpen()) close();
	}

	function onPaletteKeydown(e: KeyboardEvent) {
		if (!isOpen()) return;
		if (e.key === 'ArrowDown') {
			e.preventDefault();
			highlight(activeIndex + 1);
		} else if (e.key === 'ArrowUp') {
			e.preventDefault();
			highlight(activeIndex - 1);
		} else if (e.key === 'Enter') {
			e.preventDefault();
			const item = visibleItems()[activeIndex];
			if (item) goTo(item);
		}
	}

	function onInput(e: Event) {
		const target = e.target as Element;
		if (target.id !== 'command-palette-input') return;
		filter((target as HTMLInputElement).value);
	}

	function onClick(e: MouseEvent) {
		const target = e.target as Element;
		const item = target.closest<HTMLElement>('.command-palette-item');
		if (item) {
			goTo(item);
			return;
		}
		if (target === overlay()) close();
	}

	const w = window as typeof window & { __commandPaletteBound?: boolean };
	if (!w.__commandPaletteBound) {
		document.addEventListener('keydown', onGlobalKeydown);
		document.addEventListener('keydown', onPaletteKeydown);
		document.addEventListener('click', onClick);
		document.addEventListener('input', onInput);
		document.addEventListener('command-palette:open', open);
		w.__commandPaletteBound = true;
	}
</script>
