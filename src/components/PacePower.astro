---
---

<section class="pace-power">

  <!-- ===== Weekly Matrix ===== -->
  <div class="pp-matrix">
    <div class="pp-matrix-header">
      <p class="pp-matrix-label">Weekly Training Schedule</p>
      <p class="pp-matrix-hint">Sessions are editable. Try swapping a day.</p>
    </div>
    <div class="pp-matrix-scroll">
      <div class="pp-matrix-grid">

        <!-- Mon -->
        <div class="pp-day" id="pp-day-0" data-severity="ok">
          <div class="pp-day-label">Mon</div>
          <div class="pp-session pp-session-lift" data-value="none">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="0" data-kind="lift">
              <option value="none" selected>— none —</option>
              <option value="upper">Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy">Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="none">
            <span class="pp-session-tag">Run</span>
            <select class="pp-session-select" data-day="0" data-kind="run">
              <option value="none" selected>— none —</option>
              <option value="stairmaster">Stairmaster / incline</option>
              <option value="easy-short">Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-0" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

        <!-- Tue -->
        <div class="pp-day" id="pp-day-1" data-severity="ok">
          <div class="pp-day-label">Tue</div>
          <div class="pp-session pp-session-lift" data-value="none">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="1" data-kind="lift">
              <option value="none" selected>— none —</option>
              <option value="upper">Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy">Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="none">
            <span class="pp-session-tag">Run</span>
            <select class="pp-session-select" data-day="1" data-kind="run">
              <option value="none" selected>— none —</option>
              <option value="stairmaster">Stairmaster / incline</option>
              <option value="easy-short">Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-1" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

        <!-- Wed -->
        <div class="pp-day" id="pp-day-2" data-severity="ok">
          <div class="pp-day-label">Wed</div>
          <div class="pp-session pp-session-lift" data-value="none">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="2" data-kind="lift">
              <option value="none" selected>— none —</option>
              <option value="upper">Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy">Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="none">
            <span class="pp-session-tag">Run</span>
            <select class="pp-session-select" data-day="2" data-kind="run">
              <option value="none" selected>— none —</option>
              <option value="stairmaster">Stairmaster / incline</option>
              <option value="easy-short">Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-2" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

        <!-- Thu -->
        <div class="pp-day" id="pp-day-3" data-severity="ok">
          <div class="pp-day-label">Thu</div>
          <div class="pp-session pp-session-lift" data-value="lower-heavy">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="3" data-kind="lift">
              <option value="none">— none —</option>
              <option value="upper">Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy" selected>Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="easy-short">
            <span class="pp-session-tag">Run</span>
            <select class="pp-session-select" data-day="3" data-kind="run">
              <option value="none">— none —</option>
              <option value="stairmaster">Stairmaster / incline</option>
              <option value="easy-short" selected>Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-3" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

        <!-- Fri -->
        <div class="pp-day" id="pp-day-4" data-severity="ok">
          <div class="pp-day-label">Fri</div>
          <div class="pp-session pp-session-lift" data-value="upper">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="4" data-kind="lift">
              <option value="none">— none —</option>
              <option value="upper" selected>Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy">Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="stairmaster">
            <span class="pp-session-tag">Cardio</span>
            <select class="pp-session-select" data-day="4" data-kind="run">
              <option value="none">— none —</option>
              <option value="stairmaster" selected>Stairmaster / incline</option>
              <option value="easy-short">Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-4" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

        <!-- Sat -->
        <div class="pp-day" id="pp-day-5" data-severity="ok">
          <div class="pp-day-label">Sat</div>
          <div class="pp-session pp-session-lift" data-value="lower-heavy">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="5" data-kind="lift">
              <option value="none">— none —</option>
              <option value="upper">Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy" selected>Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="easy-short">
            <span class="pp-session-tag">Run</span>
            <select class="pp-session-select" data-day="5" data-kind="run">
              <option value="none">— none —</option>
              <option value="stairmaster">Stairmaster / incline</option>
              <option value="easy-short" selected>Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-5" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

        <!-- Sun -->
        <div class="pp-day" id="pp-day-6" data-severity="ok">
          <div class="pp-day-label">Sun</div>
          <div class="pp-session pp-session-lift" data-value="upper">
            <span class="pp-session-tag">Lift</span>
            <select class="pp-session-select" data-day="6" data-kind="lift">
              <option value="none">— none —</option>
              <option value="upper" selected>Upper body</option>
              <option value="lower-moderate">Lower — moderate</option>
              <option value="lower-heavy">Lower — heavy</option>
            </select>
          </div>
          <div class="pp-session pp-session-run" data-value="stairmaster">
            <span class="pp-session-tag">Cardio</span>
            <select class="pp-session-select" data-day="6" data-kind="run">
              <option value="none">— none —</option>
              <option value="stairmaster" selected>Stairmaster / incline</option>
              <option value="easy-short">Easy run, 3 mi</option>
              <option value="tempo">Tempo run</option>
              <option value="long">Long run, 8 mi</option>
            </select>
          </div>
          <div class="pp-fatigue-badge" id="pp-badge-6" data-severity="ok" aria-label="Fatigue badge"></div>
        </div>

      </div>

      <!-- Collision strips: one per inter-day gap -->
      <div class="pp-collision-row" aria-live="polite">
        <div class="pp-collision-strip" id="pp-strip-0" hidden data-severity="ok"></div>
        <div class="pp-collision-strip" id="pp-strip-1" hidden data-severity="ok"></div>
        <div class="pp-collision-strip" id="pp-strip-2" hidden data-severity="ok"></div>
        <div class="pp-collision-strip" id="pp-strip-3" hidden data-severity="ok"></div>
        <div class="pp-collision-strip" id="pp-strip-4" hidden data-severity="ok"></div>
        <div class="pp-collision-strip" id="pp-strip-5" hidden data-severity="ok"></div>
      </div>
    </div>

    <!-- Legend -->
    <div class="pp-legend">
      <span class="pp-legend-item" data-severity="ok">OK</span>
      <span class="pp-legend-item" data-severity="warning">Warning</span>
      <span class="pp-legend-item" data-severity="danger">Danger</span>
    </div>
  </div>

  <!-- ===== Metric Controls ===== -->
  <details class="pp-controls">
    <summary class="pp-controls-summary">
      Recovery Settings
      <span class="pp-controls-chevron" aria-hidden="true">▾</span>
    </summary>
    <div class="pp-controls-body">
      <div class="pp-control">
        <label for="pp-sleep">
          Sleep quality — <span id="pp-sleep-val">7</span>/10
          <span class="pp-control-hint">Below 6 adds +1 to all fatigue costs</span>
        </label>
        <input type="range" id="pp-sleep" min="1" max="10" value="7" />
      </div>
      <div class="pp-control">
        <label for="pp-stress">
          Systemic stress — <span id="pp-stress-val">5</span>/10
          <span class="pp-control-hint">Above 7 adds +1 to all CNS lift costs</span>
        </label>
        <input type="range" id="pp-stress" min="1" max="10" value="5" />
      </div>
      <div class="pp-control pp-control-check">
        <label>
          <input type="checkbox" id="pp-deload" />
          Deload week — halve all CNS and structural costs
        </label>
      </div>
    </div>
  </details>

  <!-- ===== Gear Tracker ===== -->
  <div class="pp-gear">
    <h3 class="pp-section-heading">Shoe Tracker</h3>
    <div class="pp-gear-grid">

      <div class="pp-shoe-card" id="pp-card-pegasus" data-status="ok">
        <div class="pp-shoe-name">Nike Pegasus 41</div>
        <div class="pp-shoe-usecase">Indoor treadmill / wet road</div>
        <label class="pp-shoe-miles-label" for="pp-miles-pegasus">Miles logged</label>
        <input type="number" id="pp-miles-pegasus" class="pp-shoe-miles"
          data-shoe="pegasus" data-threshold="400" min="0" value="0" />
        <div class="pp-shoe-bar-track">
          <div class="pp-shoe-bar-fill" id="pp-bar-pegasus" style="width:0%"></div>
        </div>
        <div class="pp-shoe-footer">
          <span class="pp-shoe-threshold-label">400 mi threshold</span>
          <span class="pp-shoe-status" id="pp-status-pegasus" data-status="ok">OK</span>
        </div>
      </div>

      <div class="pp-shoe-card" id="pp-card-zoom-fly-6" data-status="ok">
        <div class="pp-shoe-name">Nike Zoom Fly 6</div>
        <div class="pp-shoe-usecase">Dry pavement performance only</div>
        <label class="pp-shoe-miles-label" for="pp-miles-zoom-fly-6">Miles logged</label>
        <input type="number" id="pp-miles-zoom-fly-6" class="pp-shoe-miles"
          data-shoe="zoom-fly-6" data-threshold="300" min="0" value="0" />
        <div class="pp-shoe-bar-track">
          <div class="pp-shoe-bar-fill" id="pp-bar-zoom-fly-6" style="width:0%"></div>
        </div>
        <div class="pp-shoe-footer">
          <span class="pp-shoe-threshold-label">300 mi threshold</span>
          <span class="pp-shoe-status" id="pp-status-zoom-fly-6" data-status="ok">OK</span>
        </div>
      </div>

      <div class="pp-shoe-card" id="pp-card-cloud-x-4" data-status="ok">
        <div class="pp-shoe-name">On Cloud X 4</div>
        <div class="pp-shoe-usecase">Lifting floor / low-impact flush</div>
        <label class="pp-shoe-miles-label" for="pp-miles-cloud-x-4">Miles logged</label>
        <input type="number" id="pp-miles-cloud-x-4" class="pp-shoe-miles"
          data-shoe="cloud-x-4" data-threshold="500" min="0" value="0" />
        <div class="pp-shoe-bar-track">
          <div class="pp-shoe-bar-fill" id="pp-bar-cloud-x-4" style="width:0%"></div>
        </div>
        <div class="pp-shoe-footer">
          <span class="pp-shoe-threshold-label">500 mi threshold</span>
          <span class="pp-shoe-status" id="pp-status-cloud-x-4" data-status="ok">OK</span>
        </div>
      </div>

    </div>
  </div>

  <!-- ===== Confirmation Modal ===== -->
  <div class="pp-modal" id="pp-modal" role="dialog" aria-modal="true"
    aria-labelledby="pp-modal-heading" hidden>
    <div class="pp-modal-backdrop"></div>
    <div class="pp-modal-box">
      <h4 id="pp-modal-heading" class="pp-modal-heading">Log this mileage?</h4>
      <p id="pp-modal-msg" class="pp-modal-msg"></p>
      <div class="pp-modal-actions">
        <button type="button" id="pp-modal-confirm" class="pp-modal-btn pp-modal-primary">Log it</button>
        <button type="button" id="pp-modal-cancel" class="pp-modal-btn">Skip</button>
      </div>
    </div>
  </div>

</section>

<script>
  // ── Types ────────────────────────────────────────────────────────────────────
  interface LiftSession {
    name: string;
    category: 'lower-heavy' | 'lower-moderate' | 'upper';
    baseCnsCost: number;
  }
  interface RunSession {
    name: string;
    category: 'long' | 'tempo' | 'easy-short' | 'stairmaster';
    baseStructuralCost: number;
    distanceMiles?: number;
  }
  interface DayPlan {
    label: string;
    lift?: LiftSession;
    run?: RunSession;
  }
  interface CollisionFlag {
    dayIndex: number;
    severity: 'warning' | 'danger';
    reason: string;
  }
  interface RecoveryContext {
    sleepQuality: number;
    systemicStress: number;
    isDeload: boolean;
  }
  type ShoeKey = 'pegasus' | 'zoom-fly-6' | 'cloud-x-4';
  type GearState = Record<ShoeKey, number>;

  // ── Session lookup maps ───────────────────────────────────────────────────────
  const LIFT_OPTIONS: Record<string, LiftSession | undefined> = {
    'none':            undefined,
    'upper':           { name: 'Upper body',        category: 'upper',          baseCnsCost: 1 },
    'lower-moderate':  { name: 'Lower — moderate',  category: 'lower-moderate', baseCnsCost: 2 },
    'lower-heavy':     { name: 'Lower — heavy',     category: 'lower-heavy',    baseCnsCost: 3 },
  };

  const RUN_OPTIONS: Record<string, RunSession | undefined> = {
    'none':        undefined,
    'stairmaster': { name: 'Stairmaster / incline', category: 'stairmaster', baseStructuralCost: 1 },
    'easy-short':  { name: 'Easy run, 3 mi',        category: 'easy-short',  baseStructuralCost: 1, distanceMiles: 3 },
    'tempo':       { name: 'Tempo run',             category: 'tempo',       baseStructuralCost: 2 },
    'long':        { name: 'Long run, 8 mi',        category: 'long',        baseStructuralCost: 3, distanceMiles: 8 },
  };

  // ── Static week data (mutated when user edits sessions) ───────────────────────
  const WEEK: DayPlan[] = [
    { label: 'Mon' },
    { label: 'Tue' },
    { label: 'Wed' },
    {
      label: 'Thu',
      lift: LIFT_OPTIONS['lower-heavy'],
      run:  RUN_OPTIONS['easy-short'],
    },
    {
      label: 'Fri',
      lift: LIFT_OPTIONS['upper'],
      run:  RUN_OPTIONS['stairmaster'],
    },
    {
      label: 'Sat',
      lift: LIFT_OPTIONS['lower-heavy'],
      run:  RUN_OPTIONS['easy-short'],
    },
    {
      label: 'Sun',
      lift: LIFT_OPTIONS['upper'],
      run:  RUN_OPTIONS['stairmaster'],
    },
  ];

  const SHOE_THRESHOLDS: Record<ShoeKey, number> = {
    'pegasus':    400,
    'zoom-fly-6': 300,
    'cloud-x-4':  500,
  };

  const SHOE_NAMES: Record<ShoeKey, string> = {
    'pegasus':    'Nike Pegasus 41',
    'zoom-fly-6': 'Nike Zoom Fly 6',
    'cloud-x-4':  'On Cloud X 4',
  };

  // ── Module-level mutable state ───────────────────────────────────────────────
  let recovery: RecoveryContext = { sleepQuality: 7, systemicStress: 5, isDeload: false };
  let gear: GearState = { 'pegasus': 0, 'zoom-fly-6': 0, 'cloud-x-4': 0 };
  let pendingShoe: ShoeKey | null = null;
  let pendingMiles = 0;

  // ── Collision engine ─────────────────────────────────────────────────────────
  function effectiveDayCost(day: DayPlan, ctx: RecoveryContext): number {
    const deload = ctx.isDeload ? 0.5 : 1;
    const stressPenalty = ctx.systemicStress > 7 ? 1 : 0;
    const sleepPenalty  = ctx.sleepQuality < 6 ? 1 : 0;

    let cns = 0;
    if (day.lift) {
      cns = Math.max(1, Math.round(day.lift.baseCnsCost * deload)) + stressPenalty;
    }

    let structural = 0;
    if (day.run) {
      structural = Math.max(1, Math.round(day.run.baseStructuralCost * deload));
    }

    return cns + structural + sleepPenalty;
  }

  function daySeverity(cost: number): 'ok' | 'warning' | 'danger' {
    if (cost >= 5) return 'danger';
    if (cost >= 4) return 'warning';
    return 'ok';
  }

  function detectCollisions(week: DayPlan[], ctx: RecoveryContext): CollisionFlag[] {
    const flags: CollisionFlag[] = [];

    for (let i = 0; i < week.length - 1; i++) {
      const costN  = effectiveDayCost(week[i],     ctx);
      const costN1 = effectiveDayCost(week[i + 1], ctx);

      if (costN >= 5 && costN1 >= 4) {
        flags.push({
          dayIndex: i,
          severity: 'danger',
          reason: `Critical: ${week[i].label} (load ${costN}) → ${week[i+1].label} (${costN1})`,
        });
        continue;
      }

      if (costN >= 4 && costN1 >= 3) {
        flags.push({
          dayIndex: i,
          severity: 'warning',
          reason: `Elevated: ${week[i].label} (${costN}) → ${week[i+1].label} (${costN1})`,
        });
        continue;
      }

      const nIsLower  = week[i].lift?.category === 'lower-heavy' || week[i].lift?.category === 'lower-moderate';
      const n1IsLower = week[i+1].lift?.category === 'lower-heavy' || week[i+1].lift?.category === 'lower-moderate';
      if (nIsLower && n1IsLower) {
        flags.push({
          dayIndex: i,
          severity: 'warning',
          reason: `Back-to-back lower body: ${week[i].label} → ${week[i+1].label}`,
        });
      }
    }

    return flags;
  }

  // ── DOM render functions ─────────────────────────────────────────────────────
  function renderMatrix(): void {
    const collisions = detectCollisions(WEEK, recovery);
    const collisionMap = new Map<number, CollisionFlag>(collisions.map(c => [c.dayIndex, c]));

    WEEK.forEach((day, i) => {
      const cost     = effectiveDayCost(day, recovery);
      const severity = daySeverity(cost);
      const note     = cost === 0
        ? `${day.label}: Rest — no fatigue load`
        : `${day.label}: Fatigue load ${cost}`;

      const card  = document.getElementById(`pp-day-${i}`);
      const badge = document.getElementById(`pp-badge-${i}`);
      if (card)  card.dataset.severity  = severity;
      if (badge) {
        badge.dataset.severity = severity;
        badge.title = note;
        badge.setAttribute('aria-label', note);
      }

      const strip     = document.getElementById(`pp-strip-${i}`);
      if (!strip) return;
      const collision = collisionMap.get(i);
      if (collision) {
        strip.hidden = false;
        strip.dataset.severity = collision.severity;
        strip.textContent = collision.reason;
      } else {
        strip.hidden = true;
        strip.dataset.severity = 'ok';
        strip.textContent = '';
      }
    });
  }

  function renderGear(): void {
    (Object.keys(gear) as ShoeKey[]).forEach((key) => {
      const miles     = gear[key];
      const threshold = SHOE_THRESHOLDS[key];
      const pct       = Math.min(miles / threshold, 1);

      const card   = document.getElementById(`pp-card-${key}`);
      const fill   = document.getElementById(`pp-bar-${key}`);
      const status = document.getElementById(`pp-status-${key}`);
      const input  = document.querySelector<HTMLInputElement>(`[data-shoe="${key}"]`);

      const statusKey   = pct >= 1 ? 'danger' : pct >= 0.8 ? 'warning' : 'ok';
      const statusLabel = pct >= 1 ? 'Replace' : pct >= 0.8 ? 'Rotate Soon' : 'OK';

      if (fill)   fill.style.width = `${Math.round(pct * 100)}%`;
      if (input)  input.value = String(miles);
      if (status) { status.textContent = statusLabel; status.dataset.status = statusKey; }
      if (card)   card.dataset.status = statusKey;
    });
  }

  // ── localStorage helpers ─────────────────────────────────────────────────────
  function loadGear(): void {
    try {
      const raw = localStorage.getItem('pace_power_gear');
      if (raw) gear = { ...gear, ...(JSON.parse(raw) as Partial<GearState>) };
    } catch { /* ignore */ }
  }

  function saveGear(): void {
    localStorage.setItem('pace_power_gear', JSON.stringify(gear));
  }

  // ── Modal helpers ─────────────────────────────────────────────────────────────
  function openModal(shoe: ShoeKey, miles: number): void {
    pendingShoe  = shoe;
    pendingMiles = miles;
    const modal = document.getElementById('pp-modal');
    const msg   = document.getElementById('pp-modal-msg');
    if (!modal || !msg) return;
    msg.textContent = `Set ${SHOE_NAMES[shoe]} to ${miles} miles?`;
    modal.hidden = false;
    document.getElementById('pp-modal-confirm')?.focus();
  }

  function closeModal(): void {
    const modal = document.getElementById('pp-modal');
    if (modal) modal.hidden = true;
    pendingShoe  = null;
    pendingMiles = 0;
  }

  function confirmModal(): void {
    if (!pendingShoe) return;
    gear[pendingShoe] = pendingMiles;
    saveGear();
    renderGear();
    closeModal();
  }

  // ── Event handlers ───────────────────────────────────────────────────────────
  function onClick(e: MouseEvent): void {
    const target = e.target as Element;
    if (target.closest('#pp-modal-confirm')) { confirmModal(); return; }
    if (target.closest('#pp-modal-cancel'))  { closeModal();   return; }
    if ((target as HTMLElement).classList?.contains('pp-modal-backdrop')) { closeModal(); return; }
  }

  function onKeydown(e: KeyboardEvent): void {
    if (e.key === 'Escape') closeModal();
  }

  function onInput(e: Event): void {
    const target = e.target as HTMLInputElement;

    // Session selects
    if ((target as HTMLSelectElement).tagName === 'SELECT' && target.dataset.day !== undefined) {
      const dayIndex = Number(target.dataset.day);
      const kind     = target.dataset.kind as 'lift' | 'run';
      const val      = (target as HTMLSelectElement).value;

      if (kind === 'lift') {
        WEEK[dayIndex].lift = LIFT_OPTIONS[val];
      } else {
        WEEK[dayIndex].run = RUN_OPTIONS[val];
      }

      // Sync data-value on the session block so CSS can style it
      const block = target.closest<HTMLElement>('.pp-session');
      if (block) block.dataset.value = val;

      renderMatrix();
      return;
    }

    // Recovery sliders
    if (target.id === 'pp-sleep') {
      recovery.sleepQuality = Number(target.value);
      const val = document.getElementById('pp-sleep-val');
      if (val) val.textContent = target.value;
      renderMatrix();
      return;
    }

    if (target.id === 'pp-stress') {
      recovery.systemicStress = Number(target.value);
      const val = document.getElementById('pp-stress-val');
      if (val) val.textContent = target.value;
      renderMatrix();
      return;
    }

    if (target.id === 'pp-deload') {
      recovery.isDeload = target.checked;
      renderMatrix();
      return;
    }

    // Gear mileage inputs
    if (target.classList.contains('pp-shoe-miles')) {
      const shoe  = target.dataset.shoe as ShoeKey;
      const miles = Math.max(0, Number(target.value));
      if (shoe) openModal(shoe, miles);
      return;
    }
  }

  // ── Init ─────────────────────────────────────────────────────────────────────
  document.addEventListener('astro:page-load', () => {
    if ((window as any).__pacePowerBound) return;
    (window as any).__pacePowerBound = true;

    loadGear();
    renderMatrix();
    renderGear();

    document.addEventListener('click',   onClick);
    document.addEventListener('keydown', onKeydown);
    document.addEventListener('input',   onInput);
    document.addEventListener('change',  onInput);
  });
</script>

