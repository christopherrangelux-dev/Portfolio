---
// Security Puzzle — Security & Compliance's 8-bit mini-game (spec §8). Canvas
// only. Open padlocks pop up on a grid, each with a shrinking timer ring. Tap
// an open lock to patch it (+1) before its timer runs out. Miss one — let a
// lock's timer expire — and it's a breach: game over. Score = vulnerabilities
// patched; best persists.
//
// Same scaffolding as the other games: chunky pixels, two-colour palette (track
// purple + off-white) on a dark field, Press Start 2P scoped to the game UI.
---

<div class="dt-puzzle" data-puzzle>
	<canvas class="dt-puzzle-canvas" data-puzzle-canvas role="img" aria-label="Security Puzzle — tap the open locks to patch them before the timer runs out"></canvas>
</div>

<script>
	const BEST_KEY = 'dt-security-puzzle-best';
	const H = 220;

	type Lock = { col: number; row: number; life: number; max: number; flash: number };

	let rafId = 0;
	let cleanup: Array<() => void> = [];

	function readBest(): number {
		try {
			return Number(localStorage.getItem(BEST_KEY)) || 0;
		} catch {
			return 0;
		}
	}
	function writeBest(n: number) {
		try {
			localStorage.setItem(BEST_KEY, String(n));
		} catch {
			/* ignore */
		}
	}

	function setup() {
		destroy();
		const canvas = document.querySelector<HTMLCanvasElement>('[data-puzzle-canvas]');
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const palette = {
			purple: getComputedStyle(canvas).getPropertyValue('--track-color').trim() || '#7F77DD',
			ink: '#f4f1ea',
			bg: '#0f1014',
		};

		const COLS = 4;
		const ROWS = 3;
		const CELL = 56; // lock cell size
		const PAD = 12;
		let W = 0;
		let gridX = 0;
		let gridY = 0;

		function resize() {
			const dpr = Math.min(window.devicePixelRatio || 1, 2);
			W = canvas!.clientWidth || 800;
			canvas!.width = Math.round(W * dpr);
			canvas!.height = Math.round(H * dpr);
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			ctx!.imageSmoothingEnabled = false;
			const gw = COLS * CELL + (COLS - 1) * PAD;
			const gh = ROWS * CELL + (ROWS - 1) * PAD;
			gridX = (W - gw) / 2;
			gridY = (H - gh) / 2 + 8;
		}
		resize();

		const g = {
			mode: 'idle' as 'idle' | 'running' | 'over',
			t: 0,
			score: 0,
			best: readBest(),
			spawnIn: 30,
			lifeBase: 150, // frames a lock survives before breaching
			locks: [] as Lock[],
			patchFlash: 0,
		};

		function reset() {
			g.mode = 'running';
			g.t = 0;
			g.score = 0;
			g.spawnIn = 25;
			g.lifeBase = 150;
			g.locks = [];
			g.patchFlash = 0;
		}

		function cellOccupied(col: number, row: number): boolean {
			return g.locks.some((l) => l.col === col && l.row === row);
		}

		function spawnLock() {
			// pick a random free cell
			const free: Array<[number, number]> = [];
			for (let c = 0; c < COLS; c++)
				for (let r = 0; r < ROWS; r++) if (!cellOccupied(c, r)) free.push([c, r]);
			if (free.length === 0) return;
			const [col, row] = free[Math.floor(Math.random() * free.length)];
			const life = Math.max(60, g.lifeBase - g.t * 0.03);
			g.locks.push({ col, row, life, max: life, flash: 0 });
		}

		function cellRect(col: number, row: number) {
			return {
				x: gridX + col * (CELL + PAD),
				y: gridY + row * (CELL + PAD),
			};
		}

		function patchAt(px: number, py: number) {
			for (let i = g.locks.length - 1; i >= 0; i--) {
				const l = g.locks[i];
				const { x, y } = cellRect(l.col, l.row);
				if (px >= x && px <= x + CELL && py >= y && py <= y + CELL) {
					g.locks.splice(i, 1);
					g.score++;
					g.patchFlash = 8;
					if (g.score > g.best) {
						g.best = g.score;
						writeBest(g.best);
					}
					return;
				}
			}
		}

		// ---- input ----
		const onPointer = (e: PointerEvent) => {
			e.preventDefault();
			if (g.mode !== 'running') return reset();
			const rect = canvas!.getBoundingClientRect();
			const scale = W / rect.width;
			patchAt((e.clientX - rect.left) * scale, (e.clientY - rect.top) * (H / rect.height));
		};
		const onKey = (e: KeyboardEvent) => {
			if (e.code === 'Space' && g.mode !== 'running') {
				e.preventDefault();
				reset();
			}
		};
		canvas.addEventListener('pointerdown', onPointer);
		window.addEventListener('keydown', onKey);
		window.addEventListener('resize', resize);
		cleanup.push(() => canvas.removeEventListener('pointerdown', onPointer));
		cleanup.push(() => window.removeEventListener('keydown', onKey));
		cleanup.push(() => window.removeEventListener('resize', resize));

		// ---- update ----
		function update() {
			g.t++;
			if (g.patchFlash > 0) g.patchFlash--;
			if (g.mode !== 'running') return;

			g.spawnIn -= 1;
			if (g.spawnIn <= 0) {
				spawnLock();
				g.spawnIn = Math.max(28, 70 - g.t * 0.02);
			}

			for (let i = g.locks.length - 1; i >= 0; i--) {
				const l = g.locks[i];
				l.life -= 1;
				if (l.life <= 0) {
					g.mode = 'over'; // a lock breached
				}
			}
		}

		// ---- render ----
		function px(x: number, y: number, w: number, h: number, color: string) {
			ctx!.fillStyle = color;
			ctx!.fillRect(Math.round(x), Math.round(y), Math.round(w), Math.round(h));
		}
		function text(s: string, x: number, y: number, size: number, color: string, align: CanvasTextAlign = 'left') {
			ctx!.fillStyle = color;
			ctx!.font = `${size}px 'Press Start 2P', monospace`;
			ctx!.textAlign = align;
			ctx!.textBaseline = 'alphabetic';
			ctx!.fillText(s, x, y);
		}

		function drawLock(l: Lock) {
			const { x, y } = cellRect(l.col, l.row);
			const cx = x + CELL / 2;
			const ratio = l.life / l.max;
			// urgency: lock turns purple as its timer drains
			const urgent = ratio < 0.35;
			const body = urgent ? palette.purple : palette.ink;

			// timer bar under the lock
			px(x, y + CELL - 4, CELL, 3, palette.bg);
			px(x, y + CELL - 4, Math.round(CELL * ratio), 3, palette.purple);

			// open shackle (tilted up — it's unlocked)
			ctx!.strokeStyle = body;
			ctx!.lineWidth = 4;
			ctx!.beginPath();
			ctx!.arc(cx + 8, y + 16, 9, Math.PI, Math.PI * 1.9);
			ctx!.stroke();
			// lock body
			px(cx - 12, y + 18, 24, 22, body);
			// keyhole
			px(cx - 2, y + 25, 4, 5, palette.bg);
			px(cx - 1, y + 29, 2, 4, palette.bg);
		}

		function render() {
			px(0, 0, W, H, palette.bg);

			// grid backplates
			for (let c = 0; c < COLS; c++)
				for (let r = 0; r < ROWS; r++) {
					const { x, y } = cellRect(c, r);
					px(x, y, CELL, CELL, g.patchFlash > 0 ? '#191b22' : '#15161c');
				}

			for (const l of g.locks) drawLock(l);

			text(`PATCHED ${g.score}`, 12, 18, 8, palette.ink);
			text(`BEST ${g.best}`, W - 12, 18, 8, palette.purple, 'right');

			if (g.mode === 'idle') {
				px(0, H / 2 - 44, W, 88, 'rgba(15,16,20,0.82)');
				text('SECURITY PUZZLE', W / 2, H / 2 - 22, 11, palette.ink, 'center');
				text('TAP OPEN LOCKS TO PATCH THEM', W / 2, H / 2 - 4, 6, palette.purple, 'center');
				text('BEFORE THE TIMER RUNS OUT', W / 2, H / 2 + 10, 6, palette.purple, 'center');
				text('TAP TO START', W / 2, H / 2 + 28, 7, palette.ink, 'center');
			} else if (g.mode === 'over') {
				px(0, H / 2 - 40, W, 80, 'rgba(15,16,20,0.82)');
				text('BREACH!', W / 2, H / 2 - 22, 12, palette.purple, 'center');
				text(`${g.score} PATCHED`, W / 2, H / 2 - 2, 8, palette.ink, 'center');
				text('SPACE / TAP TO RETRY', W / 2, H / 2 + 18, 7, palette.purple, 'center');
			}
		}

		function loop() {
			update();
			render();
			rafId = requestAnimationFrame(loop);
		}
		(document as any).fonts?.load("8px 'Press Start 2P'").catch(() => {});
		loop();
	}

	function destroy() {
		if (rafId) cancelAnimationFrame(rafId);
		rafId = 0;
		cleanup.forEach((fn) => fn());
		cleanup = [];
	}

	setup();
	document.addEventListener('astro:page-load', setup);
	document.addEventListener('astro:before-swap', destroy);
</script>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

	.dt-puzzle {
		width: 100%;
		height: 100%;
	}
	.dt-puzzle-canvas {
		display: block;
		width: 100%;
		height: 100%;
		image-rendering: pixelated;
		border-radius: 6px;
		cursor: pointer;
		touch-action: manipulation;
	}
</style>
