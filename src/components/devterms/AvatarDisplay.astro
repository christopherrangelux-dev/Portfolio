---
// Static pixel-art designer figure (SVG). Gear overlays are added in step 8 —
// the empty slot groups below are intentional placeholders the gear step fills.
// Drawn on a 16×24 grid scaled up; flat fills only (no gradients/shadows),
// using portfolio tokens so it tracks day/night automatically.
---

<figure class="dt-avatar">
	<svg class="dt-avatar-svg" viewBox="0 0 16 24" width="96" height="144" role="img" aria-label="Your designer avatar" shape-rendering="crispEdges">
		<!-- background prop slot (gear: item) -->
		<g id="avatar-slot-item" aria-hidden="true"></g>

		<!-- hair -->
		<rect x="4" y="1" width="8" height="3" fill="var(--ink)" />
		<rect x="3" y="2" width="1" height="3" fill="var(--ink)" />
		<rect x="12" y="2" width="1" height="3" fill="var(--ink)" />
		<!-- face -->
		<rect x="4" y="4" width="8" height="5" fill="var(--dt-skin)" />
		<rect x="4" y="3" width="8" height="1" fill="var(--ink)" />
		<!-- eyes -->
		<rect x="6" y="6" width="1" height="1" fill="var(--ink)" />
		<rect x="9" y="6" width="1" height="1" fill="var(--ink)" />
		<!-- neck -->
		<rect x="7" y="9" width="2" height="1" fill="var(--dt-skin)" />
		<!-- torso (shirt = accent) -->
		<rect x="4" y="10" width="8" height="8" fill="var(--accent)" />
		<rect x="3" y="11" width="1" height="6" fill="var(--accent)" />
		<rect x="12" y="11" width="1" height="6" fill="var(--accent)" />
		<!-- hands -->
		<rect x="3" y="17" width="1" height="1" fill="var(--dt-skin)" />
		<rect x="12" y="17" width="1" height="1" fill="var(--dt-skin)" />
		<!-- legs -->
		<rect x="5" y="18" width="2" height="5" fill="var(--ink)" />
		<rect x="9" y="18" width="2" height="5" fill="var(--ink)" />
		<!-- shoes -->
		<rect x="4" y="22" width="3" height="1" fill="var(--muted)" />
		<rect x="9" y="22" width="3" height="1" fill="var(--muted)" />

		<!-- gear slots (filled in step 8) -->
		<g id="avatar-slot-badge" aria-hidden="true"></g>
		<g id="avatar-slot-accessory" aria-hidden="true"></g>
	</svg>
	<figcaption class="dt-avatar-title" id="dt-avatar-title">Embedded Designer</figcaption>
</figure>

<style>
	.dt-avatar {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
		margin: 0;
		/* skin tone is local to the avatar; not a global token */
		--dt-skin: #e8b894;
	}
	.dt-avatar-svg {
		image-rendering: pixelated;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--paper);
		padding: 0.5rem;
	}
	.dt-avatar-title {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		color: var(--muted);
		text-align: center;
	}
</style>
