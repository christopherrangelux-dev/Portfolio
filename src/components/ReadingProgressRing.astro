---
interface Props {
	accentColor: string;
}

const { accentColor } = Astro.props;
---

<div id="reading-progress-ring" aria-hidden="true" style={`--ring-accent: ${accentColor}`}>
	<svg viewBox="0 0 40 40">
		<circle class="ring-track" cx="20" cy="20" r="18" />
		<circle class="ring-arc" cx="20" cy="20" r="18" />
		<polygon class="ring-aperture" points="" />
	</svg>
</div>

<style>
	#reading-progress-ring {
		position: fixed;
		bottom: 24px;
		right: 24px;
		width: 40px;
		height: 40px;
		pointer-events: none;
		z-index: 9998;
		transition: opacity 400ms ease, transform 400ms ease;
	}

	#reading-progress-ring.is-leaving {
		opacity: 0;
		transform: scale(0.8);
	}

	#reading-progress-ring svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.ring-track {
		fill: none;
		stroke: var(--border);
		stroke-width: 2;
	}

	.ring-arc {
		fill: none;
		stroke: var(--ring-accent, var(--accent));
		stroke-width: 2;
		stroke-linecap: round;
		transform: rotate(-90deg);
		transform-origin: 20px 20px;
		transition: stroke-dashoffset 80ms linear;
	}

	.ring-aperture {
		fill: none;
		stroke: var(--muted);
		stroke-width: 1.5;
		transform-origin: 20px 20px;
		transition: transform 80ms linear;
	}

	.ring-arc.is-pulsing {
		animation: reading-ring-pulse 360ms ease-out;
	}

	@keyframes reading-ring-pulse {
		0% {
			stroke-width: 2;
		}
		50% {
			stroke-width: 4;
		}
		100% {
			stroke-width: 2;
		}
	}

	@media (max-width: 600px) {
		#reading-progress-ring {
			bottom: 16px;
			right: 16px;
			width: 32px;
			height: 32px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#reading-progress-ring {
			transition: none;
		}

		.ring-arc {
			transition: none;
		}

		.ring-aperture {
			transition: none;
		}

		.ring-arc.is-pulsing {
			animation: none;
		}
	}
</style>

<script>
	function hexagonPoints(cx: number, cy: number, r: number) {
		const pts: string[] = [];
		for (let i = 0; i < 6; i++) {
			const angle = (Math.PI / 3) * i - Math.PI / 2;
			pts.push(`${cx + r * Math.cos(angle)},${cy + r * Math.sin(angle)}`);
		}
		return pts.join(' ');
	}

	function setupReadingProgressRing() {
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const RADIUS = 18;
		const CIRCUMFERENCE = 2 * Math.PI * RADIUS;
		const MIN_APERTURE_R = 6;
		const MAX_APERTURE_R = 12;

		let raf = 0;
		let done = false;

		function render(progress: number) {
			const ring = document.getElementById('reading-progress-ring');
			if (!ring) return;
			const arc = ring.querySelector<SVGCircleElement>('.ring-arc');
			const aperture = ring.querySelector<SVGPolygonElement>('.ring-aperture');
			if (!arc || !aperture) return;

			arc.style.strokeDasharray = `${CIRCUMFERENCE}`;
			arc.style.strokeDashoffset = `${CIRCUMFERENCE * (1 - progress)}`;

			const apertureR = MAX_APERTURE_R - (MAX_APERTURE_R - MIN_APERTURE_R) * progress;
			aperture.setAttribute('points', hexagonPoints(20, 20, apertureR));

			if (progress >= 1 && !done) {
				done = true;
				finish(ring, arc);
			}
		}

		function finish(ring: HTMLElement, arc: SVGCircleElement) {
			if (reduceMotion) {
				ring.remove();
				return;
			}
			arc.classList.add('is-pulsing');
			setTimeout(() => {
				ring.classList.add('is-leaving');
				setTimeout(() => ring.remove(), 400);
			}, 360);
		}

		function update() {
			const body = document.querySelector('.case-study-body');
			if (!body) {
				raf = 0;
				return;
			}
			const { top, height } = body.getBoundingClientRect();
			const viewH = window.innerHeight;
			const progress = Math.min(Math.max(-top / (height - viewH), 0), 1);
			render(progress);
			raf = 0;
		}

		function onScroll() {
			if (raf) return;
			raf = requestAnimationFrame(update);
		}

		function reset() {
			done = false;
			const ring = document.getElementById('reading-progress-ring');
			ring?.classList.remove('is-leaving');
			ring?.querySelector('.ring-arc')?.classList.remove('is-pulsing');
			if (ring) ring.style.display = '';
			update();
		}

		window.addEventListener('scroll', onScroll);
		document.addEventListener('astro:page-load', reset);
		update();
	}

	const w = window as typeof window & { __readingProgressRingBound?: boolean };
	if (!w.__readingProgressRingBound) {
		setupReadingProgressRing();
		w.__readingProgressRingBound = true;
	}
</script>
