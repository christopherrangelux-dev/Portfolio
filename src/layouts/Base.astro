---
import '../styles/global.css';
import { withBase } from '../lib/url';
import { ClientRouter } from 'astro:transitions';
import Lightbox from '../components/Lightbox.astro';
import CommandPalette from '../components/CommandPalette.astro';
import CursorLens from '../components/CursorLens.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import { getSeason } from '../lib/season';

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideScrollProgress?: boolean;
}

const {
  title,
  description = 'Christopher Rangel — Product Designer',
  image = 'og/home.png',
  hideScrollProgress = false,
} = Astro.props;
const path = Astro.url.pathname;
const ogImageUrl = new URL(withBase(image), Astro.site).toString();

const navLink = (href: string) => withBase(href);
const isActive = (href: string) => path === navLink(href) || (href === '' && path === withBase('/'));

const GA_MEASUREMENT_ID = 'G-NWPBLHXZBS';

// Computed at build time only — baked into the static HTML for every
// visitor. Unlike data-theme (day/night), which is a per-visitor runtime
// preference read from localStorage, the season is the same for everyone
// until the next build.
const season = getSeason();
---

<html lang="en" data-season={season}>
	<head>
		<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`} is:inline></script>
		<script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());
			// View Transitions swap pages without a full reload, so the automatic
			// page_view on config would only ever fire once. Send it manually on
			// every astro:page-load instead, which covers the first load too.
			gtag('config', GA_MEASUREMENT_ID, { send_page_view: false });

			// astro:page-load can fire more than once for the same navigation
			// (e.g. when a link was prefetched), so skip if the path didn't change.
			var lastTrackedPath = null;
			document.addEventListener('astro:page-load', () => {
				if (window.location.pathname === lastTrackedPath) return;
				lastTrackedPath = window.location.pathname;
				gtag('event', 'page_view', {
					page_location: window.location.href,
					page_title: document.title,
				});
			});
		</script>
		<meta charset="utf-8" />
		<script is:inline>
			(function () {
				var stored = localStorage.getItem('theme');
				var theme =
					stored === 'night' || stored === 'day'
						? stored
						: window.matchMedia('(prefers-color-scheme: dark)').matches
							? 'night'
							: 'day';
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<ClientRouter />
	</head>
	<body>
		{!hideScrollProgress && <ScrollProgress />}
		<header class="site-header">
			<div class="container">
				<a class="brand" href={navLink('')}>
					<svg class="brand-mark" viewBox="2 -1 20 20" aria-hidden="true">
						<line x1="4" y1="14" x2="9" y2="5" stroke="var(--muted)" stroke-width="1" stroke-linecap="round" />
						<line x1="9" y1="5" x2="14" y2="9" stroke="var(--muted)" stroke-width="1" stroke-linecap="round" />
						<circle cx="4" cy="14" r="1.3" fill="var(--ink)" />
						<circle cx="9" cy="5" r="1.5" fill="var(--ink)" />
						<circle cx="14" cy="9" r="2" fill="var(--accent)" />
						<circle cx="19" cy="4" r="1.1" fill="var(--ink)" />
						<circle cx="20.5" cy="14" r="0.8" fill="var(--ink)" />
					</svg>
					Christopher Rangel
				</a>
				<div class="site-header-controls">
					<button class="cmdk-hint" type="button" aria-label="Open command palette">
						<span class="cmdk-hint-kbd"><kbd>&#8984;</kbd><kbd>K</kbd></span>
						<svg class="cmdk-hint-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="11" cy="11" r="7"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
					</button>
					<button class="theme-toggle" aria-label="Night theme" aria-pressed="false">
						<svg class="theme-toggle-icon theme-toggle-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="12" r="4"></circle>
							<line x1="12" y1="2" x2="12" y2="4"></line>
							<line x1="12" y1="20" x2="12" y2="22"></line>
							<line x1="4.93" y1="4.93" x2="6.34" y2="6.34"></line>
							<line x1="17.66" y1="17.66" x2="19.07" y2="19.07"></line>
							<line x1="2" y1="12" x2="4" y2="12"></line>
							<line x1="20" y1="12" x2="22" y2="12"></line>
							<line x1="4.93" y1="19.07" x2="6.34" y2="17.66"></line>
							<line x1="17.66" y1="6.34" x2="19.07" y2="4.93"></line>
						</svg>
						<svg class="theme-toggle-icon theme-toggle-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
						</svg>
					</button>
					<button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-nav">
						<span></span><span></span><span></span>
					</button>
					<nav class="site-nav" id="site-nav">
						<a href={navLink('')} class={isActive('') ? 'active' : ''}>Home</a>
						<a href={navLink('work')} class={isActive('work') ? 'active' : ''}>Work</a>
						<a href={navLink('about')} class={isActive('about') ? 'active' : ''}>About</a>
						<a href={navLink('photos')} class={isActive('photos') ? 'active' : ''}>Photos</a>
						<a href={navLink('contact')} class={isActive('contact') ? 'active' : ''}>Contact</a>
						<a href={withBase('resume.pdf')} target="_blank" rel="noopener">Resume</a>
					</nav>
				</div>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container">
				<p>
					&copy; {new Date().getFullYear()} Christopher Rangel. Built with Astro, deployed on GitHub Pages.
					&middot; <a href={navLink('colophon')}>Colophon</a>
					&middot; <a href={navLink('now')}>Now</a>
					&middot; <a href={navLink('uses')}>Uses</a>
					&middot; <a href={navLink('recipes')}>Recipes</a>
				</p>
			</div>
		</footer>

		<Lightbox />
		<CommandPalette />
		<CursorLens />

		<script>
			function closeNav() {
				document.getElementById('site-nav')?.classList.remove('is-open');
				document.querySelector('.nav-toggle')?.setAttribute('aria-expanded', 'false');
			}

			function setTheme(theme: 'day' | 'night') {
				document.documentElement.dataset.theme = theme;
				localStorage.setItem('theme', theme);
				document.querySelector('.theme-toggle')?.setAttribute('aria-pressed', String(theme === 'night'));
			}

			function onClick(e: MouseEvent) {
				const target = e.target as Element;

				if (target.closest('.cmdk-hint')) {
					document.dispatchEvent(new CustomEvent('command-palette:open'));
					return;
				}

				if (target.closest('.theme-toggle')) {
					setTheme(document.documentElement.dataset.theme === 'night' ? 'day' : 'night');
					return;
				}

				const toggle = target.closest('.nav-toggle');
				const nav = document.getElementById('site-nav');
				if (!nav) return;

				if (toggle) {
					const isOpen = nav.classList.toggle('is-open');
					toggle.setAttribute('aria-expanded', String(isOpen));
					return;
				}

				if (!nav.classList.contains('is-open')) return;
				if (target.closest('#site-nav a')) {
					closeNav();
				} else if (!nav.contains(target)) {
					closeNav();
				}
			}

			function onKeydown(e: KeyboardEvent) {
				if (e.key === 'Escape') closeNav();
			}

			document
				.querySelector('.theme-toggle')
				?.setAttribute('aria-pressed', String(document.documentElement.dataset.theme === 'night'));

			const w = window as typeof window & { __navBound?: boolean };
			if (!w.__navBound) {
				document.addEventListener('click', onClick);
				document.addEventListener('keydown', onKeydown);
				w.__navBound = true;
			}
		</script>
	</body>
</html>
