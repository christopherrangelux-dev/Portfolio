---
import '../styles/global.css';
import { withBase } from '../lib/url';
import { ClientRouter } from 'astro:transitions';
import Lightbox from '../components/Lightbox.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Christopher Rangel — Product Designer' } = Astro.props;
const path = Astro.url.pathname;

const navLink = (href: string) => withBase(href);
const isActive = (href: string) => path === navLink(href) || (href === '' && path === withBase('/'));
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<header class="site-header">
			<div class="container">
				<a class="brand" href={navLink('')}>Christopher Rangel</a>
				<button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-nav">
					<span></span><span></span><span></span>
				</button>
				<nav class="site-nav" id="site-nav">
					<a href={navLink('')} class={isActive('') ? 'active' : ''}>Home</a>
					<a href={navLink('work')} class={isActive('work') ? 'active' : ''}>Work</a>
					<a href={navLink('about')} class={isActive('about') ? 'active' : ''}>About</a>
					<a href={navLink('contact')} class={isActive('contact') ? 'active' : ''}>Contact</a>
					<a href={withBase('resume.pdf')} target="_blank" rel="noopener">Resume</a>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container">
				<p>&copy; {new Date().getFullYear()} Christopher Rangel. Built with Astro, deployed on GitHub Pages.</p>
			</div>
		</footer>

		<Lightbox />

		<script>
			function closeNav() {
				document.getElementById('site-nav')?.classList.remove('is-open');
				document.querySelector('.nav-toggle')?.setAttribute('aria-expanded', 'false');
			}

			function onClick(e: MouseEvent) {
				const target = e.target as Element;
				const toggle = target.closest('.nav-toggle');
				const nav = document.getElementById('site-nav');
				if (!nav) return;

				if (toggle) {
					const isOpen = nav.classList.toggle('is-open');
					toggle.setAttribute('aria-expanded', String(isOpen));
					return;
				}

				if (!nav.classList.contains('is-open')) return;
				if (target.closest('#site-nav a')) {
					closeNav();
				} else if (!nav.contains(target)) {
					closeNav();
				}
			}

			function onKeydown(e: KeyboardEvent) {
				if (e.key === 'Escape') closeNav();
			}

			const w = window as typeof window & { __navBound?: boolean };
			if (!w.__navBound) {
				document.addEventListener('click', onClick);
				document.addEventListener('keydown', onKeydown);
				w.__navBound = true;
			}
		</script>
	</body>
</html>
