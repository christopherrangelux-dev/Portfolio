---
import Base from '../../../layouts/Base.astro';
import { withBase } from '../../../lib/url';
import { TRACKS, getTrack } from '../../../data/devterms/content';
import TrackPage from '../../../components/devterms/TrackPage.astro';
import GlossaryPanel from '../../../components/devterms/GlossaryPanel.astro';

import '../../../styles/devterms.css';

export function getStaticPaths() {
	return TRACKS.map((track) => ({ params: { track: track.slug } }));
}

const { track: trackSlug } = Astro.params;
const track = getTrack(trackSlug!)!;
---

<Base title={`${track.name} — Field Manual`} description={track.tagline}>
	<div class="container devterms" style={`--track-color: ${track.color}`}>
		<a class="dt-back-link" href={withBase('field-manual')}>← All tracks</a>
		<section class="dt-hero">
			<p class="dt-eyebrow">{track.missionTheme}</p>
			<div class="dt-hero-title-row">
				<h1>{track.name}</h1>
				<GlossaryPanel />
			</div>
			<p class="dt-lede">{track.tagline}</p>
		</section>

		<TrackPage trackSlug={track.slug} />
	</div>
</Base>
