---
import Base from '../../../layouts/Base.astro';
import { withBase } from '../../../lib/url';
import { TRACKS, getTrack, getLevel } from '../../../data/devterms/content';
import LevelFlow from '../../../components/devterms/LevelFlow.astro';
import GlossaryPanel from '../../../components/devterms/GlossaryPanel.astro';

import '../../../styles/devterms.css';

export function getStaticPaths() {
	return TRACKS.flatMap((track) =>
		Array.from({ length: track.levelCount }, (_, i) => ({
			params: { track: track.slug, level: String(i + 1) },
		}))
	);
}

const { track: trackSlug, level } = Astro.params;
const track = getTrack(trackSlug!)!;
const levelNum = Number(level);
const lvl = getLevel(trackSlug!, levelNum);
---

<Base title={`${track.name} · Level ${levelNum} — Dev Terms`} description={track.tagline}>
	<div class="container devterms" style={`--track-color: ${track.color}`}>
		<a class="dt-back-link" href={withBase(`dev-terms/${track.slug}`)}>← {track.name}</a>
		<section class="dt-hero">
			<p class="dt-eyebrow">{track.name} · Level {levelNum}</p>
			<h1>{lvl ? lvl.title : 'Mission briefing'}</h1>
		</section>

		{
			lvl ? (
				<LevelFlow trackSlug={track.slug} level={levelNum} />
			) : (
				<p class="dt-placeholder">This mission isn't authored yet — check back soon.</p>
			)
		}
	</div>
	<GlossaryPanel />
</Base>
