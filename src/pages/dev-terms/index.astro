---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../lib/url';
import Dashboard from '../../components/devterms/Dashboard.astro';
import GlossaryPanel from '../../components/devterms/GlossaryPanel.astro';
import '../../styles/devterms.css';
---

<Base
	title="Dev Terms — Christopher Rangel"
	description="A gamified dev vocabulary trainer for designers — learn the language engineers use every sprint, through scenario-based field missions."
>
	<div class="container devterms">
		<section class="dt-hero">
			<p class="dt-eyebrow">Field Manual</p>
			<div class="dt-hero-title-row">
				<h1>Dev Terms</h1>
				<GlossaryPanel />
			</div>
			<p class="dt-lede">
				The language engineers use every sprint, learned by doing. Six tracks, scenario-based
				missions, one growing field notebook.
			</p>
		</section>

		<Dashboard />

		<p class="dt-footer-link">
			<a href={withBase('dev-terms/glossary')}>Open the field notebook →</a>
		</p>
	</div>
</Base>
