---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';
import { parseMetric } from '../../lib/metric';
import PatternSVG from '../../components/PatternSVG.astro';
import ConstellationMap from '../../components/ConstellationMap.astro';

const allWork = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
// Tier 1 is the two most senior/complex pieces (lowest `order`), independent of the
// `featured` flag, which drives a separate set of picks on the home page.
const featured = allWork.slice(0, 2);
const supporting = allWork.slice(2);
const allTags = [...new Set(allWork.flatMap((p) => p.data.tags ?? []))];
---

<Base title="Work — Christopher Rangel" description="Case studies by Christopher Rangel, Product Designer">
	<div class="container">
		<section class="hero work-hero">
			<h1>Work</h1>
			<p>
				Case studies in systems design, from AI infrastructure to service design for
				nonprofits, plus one rebuilt from scratch in the kitchen.
			</p>
			<p class="work-count">{allWork.length} projects</p>
		</section>

		<div class="work-toolbar">
			<div class="tag-filter-bar" role="toolbar" aria-label="Filter projects by tag">
				<button type="button" class="tag-filter-btn is-active" data-tag="all" aria-pressed="true">All</button>
				{allTags.map((tag) => (
					<button type="button" class="tag-filter-btn" data-tag={tag} aria-pressed="false">{tag}</button>
				))}
			</div>

			<div class="view-toggle-bar" role="toolbar" aria-label="Switch work view">
				<button type="button" class="view-toggle-btn is-active" data-view="grid" aria-pressed="true">Grid</button>
				<button type="button" class="view-toggle-btn" data-view="map" aria-pressed="false">Map</button>
			</div>
		</div>

		<div id="work-grid-view">
			<div class="work-tier work-tier-1">
				{featured.map((project) => {
					const m = parseMetric(project.data.metric);
					return (
						<a
							class="work-card work-card-featured"
							href={withBase(`work/${project.id}`)}
							data-tags={(project.data.tags ?? []).join('|')}
							style={`--card-color: ${project.data.color}`}
						>
							<div class="work-card-visual" style={`color: ${project.data.color}`}>
								<PatternSVG pattern={project.data.pattern} />
							</div>
							<h3 transition:name={`work-title-${project.id}`}>{project.data.name}</h3>
							<p class="work-card-subtitle">{project.data.subtitle}</p>
							<div class="metric-callout">
								{m.staticPrefix && <span class="metric-static">{m.staticPrefix}</span>}
								<span
									class="metric-value"
									transition:name={`work-metric-${project.id}`}
									data-metric
									data-metric-end={m.end}
									data-metric-prefix={m.animPrefix}
									data-metric-suffix={m.animSuffix}
									data-metric-comma={m.comma ? '1' : ''}
								>
									{m.animPrefix}{m.comma ? m.end.toLocaleString() : m.end}{m.animSuffix}
								</span>
								<span class="metric-label">{project.data.metricLabel}</span>
							</div>
							{project.data.tags && (
								<div class="tag-list">
									{project.data.tags.map((tag) => <span class="tag-pill">{tag}</span>)}
								</div>
							)}
							<span class="work-card-link">View case study &rarr;</span>
						</a>
					);
				})}
			</div>

			<div class="work-tier work-tier-2">
				{supporting.map((project) => {
					const m = parseMetric(project.data.metric);
					return (
						<a
							class="work-card work-card-supporting"
							href={withBase(`work/${project.id}`)}
							data-tags={(project.data.tags ?? []).join('|')}
							style={`--card-color: ${project.data.color}`}
						>
							<div class="work-card-pattern-bg" style={`color: ${project.data.color}`} aria-hidden="true">
								<PatternSVG pattern={project.data.pattern} />
							</div>
							<h3 transition:name={`work-title-${project.id}`}>{project.data.name}</h3>
							<p class="work-card-subtitle">{project.data.subtitle}</p>
							<div class="metric-callout metric-callout-small">
								{m.staticPrefix && <span class="metric-static">{m.staticPrefix}</span>}
								<span
									class="metric-value"
									transition:name={`work-metric-${project.id}`}
									data-metric
									data-metric-end={m.end}
									data-metric-prefix={m.animPrefix}
									data-metric-suffix={m.animSuffix}
									data-metric-comma={m.comma ? '1' : ''}
								>
									{m.animPrefix}{m.comma ? m.end.toLocaleString() : m.end}{m.animSuffix}
								</span>
								<span class="metric-label">{project.data.metricLabel}</span>
							</div>
							{project.data.tags && (
								<div class="tag-list">
									{project.data.tags.map((tag) => <span class="tag-pill">{tag}</span>)}
								</div>
							)}
						</a>
					);
				})}
			</div>
		</div>

		<div id="work-map-view" hidden>
			<ConstellationMap work={allWork} />
		</div>

		<script is:inline>
			(function () {
				var isMap = location.search.includes('view=map');
				var gridView = document.getElementById('work-grid-view');
				var mapView = document.getElementById('work-map-view');
				if (gridView) gridView.hidden = isMap;
				if (mapView) mapView.hidden = !isMap;
				var gridBtn = document.querySelector('.view-toggle-btn[data-view="grid"]');
				var mapBtn = document.querySelector('.view-toggle-btn[data-view="map"]');
				if (gridBtn && mapBtn) {
					gridBtn.classList.toggle('is-active', !isMap);
					gridBtn.setAttribute('aria-pressed', String(!isMap));
					mapBtn.classList.toggle('is-active', isMap);
					mapBtn.setAttribute('aria-pressed', String(isMap));
				}
			})();
		</script>
	</div>
</Base>

<script>
	import { setupMetricCounters } from '../../lib/metricCounter';

	function setupTagFilter() {
		const bar = document.querySelector('.tag-filter-bar');
		if (!bar) return;

		const buttons = Array.from(bar.querySelectorAll<HTMLButtonElement>('.tag-filter-btn'));
		const cards = Array.from(document.querySelectorAll<HTMLElement>('.work-card'));
		let activeIndex = 0;

		function applyFilter(tag: string) {
			cards.forEach((card) => {
				const tags = card.dataset.tags?.split('|') ?? [];
				const show = tag === 'all' || tags.includes(tag);
				card.classList.toggle('is-filtered-out', !show);
			});
		}

		function setActive(button: HTMLButtonElement) {
			buttons.forEach((b) => {
				b.classList.toggle('is-active', b === button);
				b.setAttribute('aria-pressed', String(b === button));
			});
			applyFilter(button.dataset.tag ?? 'all');
		}

		function onClick(e: MouseEvent) {
			const target = e.target as Element;
			const button = target.closest<HTMLButtonElement>('.tag-filter-btn');
			if (button) {
				activeIndex = buttons.indexOf(button);
				setActive(button);
			}
		}

		function onKeydown(e: KeyboardEvent) {
			if (!buttons.includes(document.activeElement as HTMLButtonElement)) return;
			if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
				e.preventDefault();
				activeIndex = (activeIndex + (e.key === 'ArrowRight' ? 1 : -1) + buttons.length) % buttons.length;
				buttons[activeIndex].focus();
			} else if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				setActive(document.activeElement as HTMLButtonElement);
			}
		}

		bar.addEventListener('click', onClick);
		bar.addEventListener('keydown', onKeydown);
	}

	function syncViewFromUrl() {
		const isMap = location.search.includes('view=map');
		const gridView = document.getElementById('work-grid-view');
		const mapView = document.getElementById('work-map-view');
		if (gridView) gridView.hidden = isMap;
		if (mapView) mapView.hidden = !isMap;

		const gridBtn = document.querySelector<HTMLButtonElement>('.view-toggle-btn[data-view="grid"]');
		const mapBtn = document.querySelector<HTMLButtonElement>('.view-toggle-btn[data-view="map"]');
		if (gridBtn && mapBtn) {
			gridBtn.classList.toggle('is-active', !isMap);
			gridBtn.setAttribute('aria-pressed', String(!isMap));
			mapBtn.classList.toggle('is-active', isMap);
			mapBtn.setAttribute('aria-pressed', String(isMap));
		}
	}

	function setupViewToggle() {
		const bar = document.querySelector('.view-toggle-bar');
		if (!bar) return;

		function onClick(e: MouseEvent) {
			const target = e.target as Element;
			const button = target.closest<HTMLButtonElement>('.view-toggle-btn');
			if (!button) return;

			const view = button.dataset.view;
			const url = new URL(location.href);
			if (view === 'map') {
				url.searchParams.set('view', 'map');
			} else {
				url.searchParams.delete('view');
			}
			history.pushState({}, '', url);
			syncViewFromUrl();
		}

		const w = bar as HTMLElement & { __viewToggleBound?: boolean };
		if (!w.__viewToggleBound) {
			bar.addEventListener('click', onClick);
			w.__viewToggleBound = true;
		}
	}

	// The is:inline blocking script handles the very first paint (before
	// hydration) to avoid a flash of the wrong view. This re-runs the same
	// sync on every Astro view-transition navigation (including back/forward
	// to a different ?view= state), since is:inline only runs once on initial
	// HTML parse.
	document.addEventListener('astro:page-load', () => {
		syncViewFromUrl();
		setupViewToggle();
	});

	setupTagFilter();
	setupViewToggle();
	setupMetricCounters();
</script>
