---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);

const allWork = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allWork.findIndex((p) => p.id === project.id);
const prevProject = allWork[(currentIndex - 1 + allWork.length) % allWork.length];
const nextProject = allWork[(currentIndex + 1) % allWork.length];
---

<Base title={`${project.data.title} — Christopher Rangel`} description={project.data.subtitle}>
	<a class="back-link" href={withBase('')}>&larr; Back to all work</a>
	<div class="case-study-header container">
		<h1>{project.data.title}</h1>
		<p class="subtitle">{project.data.subtitle}</p>
		{project.data.snapshot && (
			<dl class="case-study-snapshot">
				<div><dt>Role</dt><dd>{project.data.snapshot.role}</dd></div>
				<div><dt>Timeline</dt><dd>{project.data.snapshot.timeline}</dd></div>
				<div><dt>Tools</dt><dd>{project.data.snapshot.tools}</dd></div>
				<div><dt>Team</dt><dd>{project.data.snapshot.team}</dd></div>
			</dl>
		)}
	</div>
	<div class="case-study-body prose">
		<Content />
	</div>
	{allWork.length > 1 && (
		<nav class="project-nav" aria-label="More projects">
			<div class="container">
				<a class="project-nav-link project-nav-prev" href={withBase(`work/${prevProject.id}`)}>
					<span class="project-nav-arrow" aria-hidden="true">&lsaquo;</span>
					<span>
						<span class="project-nav-label">Previous</span>
						<span class="project-nav-title">{prevProject.data.name}</span>
					</span>
				</a>
				<a class="project-nav-link project-nav-next" href={withBase(`work/${nextProject.id}`)}>
					<span>
						<span class="project-nav-label">Next</span>
						<span class="project-nav-title">{nextProject.data.name}</span>
					</span>
					<span class="project-nav-arrow" aria-hidden="true">&rsaquo;</span>
				</a>
			</div>
		</nav>
	)}
</Base>
