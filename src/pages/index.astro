---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const allWork = await getCollection('work');
const featured = allWork.filter((p) => p.data.featured).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Christopher Rangel — Product Designer">
	<div class="container">
		<section class="hero">
			<h1>Product Designer who bakes and chases patterns — in the kitchen, the night sky, and the systems I design.</h1>
			<p>
				I design systems that make complex, high-stakes work feel simple — from AI-agent
				infrastructure to enterprise design platforms. My background spans the classroom to the
				boardroom, and I bring the same instinct for clarity to both: notice the pattern,
				simplify the path, close the gap.
			</p>
		</section>

		<section class="principles">
			<div class="principle-card">
				<h3>Systems Thinking, Human Outcomes</h3>
				<p>
					The best system is invisible; it just works. I design for the architecture
					underneath, not just the screen on top.
				</p>
			</div>
			<div class="principle-card">
				<h3>Evidence Over Authority</h3>
				<p>
					People don't act on a verdict, they act on understanding why. I build trust into
					the data, not just the decision.
				</p>
			</div>
			<div class="principle-card">
				<h3>Patterns, Wherever They Hide</h3>
				<p>
					Whether it's a leaf vein, a night sky, or an API platform, I notice structure —
					and that's where good design starts.
				</p>
			</div>
		</section>
	</div>

	<div class="photo-break">
		<img src={withBase('images/laguna-sunset.jpg')} alt="Sunset over the ocean" loading="lazy" />
	</div>

	<div class="container">
		<h2 class="section-title">Featured Work</h2>
		<div class="work-grid">
			{featured.map((project) => (
				<a class="work-card" href={withBase(`work/${project.id}`)}>
					<div class="thumb-wrap">
						<img src={withBase(`images/${project.data.thumbnail}`)} alt={project.data.name} loading="lazy" />
					</div>
					<h3>{project.data.name}</h3>
				</a>
			))}
		</div>
		<p><a href={withBase('work')} style="border-bottom: 1px solid var(--ink);">See all work &rarr;</a></p>

		<p class="human-thread">
			When I'm not designing systems, I'm baking them — or photographing the patterns in
			between. More on <a href="https://www.youtube.com/@chrisrangelUX" target="_blank" rel="noopener" style="border-bottom: 1px solid var(--ink);">YouTube</a>.
		</p>

		<p class="contact-cta">
			Let's talk — <a href={withBase('contact')} style="border-bottom: 1px solid var(--ink);">get in touch</a>.
		</p>
	</div>
</Base>
