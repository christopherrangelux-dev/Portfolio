---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';
import { parseMetric } from '../lib/metric';
import PatternSVG from '../components/PatternSVG.astro';

const tokenNames = ['ink', 'paper', 'muted', 'accent', 'accent-indigo', 'border'];

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const xdLibrary = work.find((p) => p.id === 'xd-library')!;
const xdMetric = parseMetric(xdLibrary.data.metric);
---

<Base
	title="Design System — Christopher Rangel"
	description="A living reference for the type scale, color tokens, and components behind this site."
>
	<div class="container">
		<section class="hero">
			<h1>Design System</h1>
			<p>
				The real type scale, color tokens, and components this site is built from, rendered
				as themselves rather than redrawn as static images. Grew out of the <a href={withBase('work/xd-library')} style="border-bottom: 1px solid var(--ink);">XD Library</a> case study.
			</p>
		</section>

		<h2 class="section-title">Color Tokens</h2>
		<p class="principle-card-meta">Reads the live CSS variables, so these reflect whichever theme is active right now — try the night toggle.</p>
		<div class="swatch-grid">
			{tokenNames.map((name) => (
				<div class="swatch">
					<div class="swatch-color" style={`background: var(--${name});`}></div>
					<p class="swatch-name">--{name}</p>
					<p class="principle-card-meta" data-token-value={name}></p>
				</div>
			))}
		</div>

		<h2 class="section-title">Type Scale</h2>
		<div class="showcase-samples">
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Hero heading',
					component: '<h1> in .hero',
					vars: [],
					styles: ['font-size: 2rem', 'line-height: 1.25', 'font-weight: 500', 'margin: 0 0 1.25rem'],
				})}
			>
				<div class="hero" style="padding: 0;">
					<h1>Product Designer who bakes and chases patterns.</h1>
				</div>
				<p class="principle-card-meta">.hero h1, 2rem</p>
			</div>
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Case study header heading',
					component: '<h1> in .case-study-header',
					vars: [],
					styles: ['font-size: 1.9rem', 'line-height: 1.25', 'font-weight: 500', 'margin-bottom: 0.75rem'],
				})}
			>
				<div class="case-study-header" style="padding: 0;">
					<h1>One Shared Backend Instead of a Dozen Siloed Ones</h1>
				</div>
				<p class="principle-card-meta">.case-study-header h1, 1.9rem</p>
			</div>
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Section title',
					component: '<h2 class="section-title" />',
					vars: [],
					styles: ['font-size: 1.4rem', 'line-height: 1.25', 'font-weight: 500', 'margin: 3rem 0 1.5rem'],
				})}
			>
				<h2 class="section-title" style="margin: 0;">Featured Work</h2>
				<p class="principle-card-meta">.section-title, 1.4rem</p>
			</div>
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Case study body heading',
					component: '<h2> in .case-study-body',
					vars: [],
					styles: ['font-size: 1.25rem', 'line-height: 1.25', 'font-weight: 500', 'margin-top: 2.5rem'],
				})}
			>
				<div class="case-study-body" style="margin: 0; padding: 0; max-width: none;">
					<h2 style="margin-top: 0;">The Decision</h2>
				</div>
				<p class="principle-card-meta">.case-study-body h2, 1.25rem</p>
			</div>
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Body text',
					component: '<p> (default)',
					vars: [],
					styles: ['font-family: Lora, serif', 'font-size: 1rem', 'line-height: 1.6', 'font-weight: 400'],
				})}
			>
				<p style="margin: 0;">
					Body text sets in Lora at 1rem with 1.6 line-height. Long-form case-study prose
					reads at this size throughout the site.
				</p>
				<p class="principle-card-meta">body p, 1rem</p>
			</div>
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Work card subtitle',
					component: '<p class="work-card-subtitle" />',
					vars: [['--muted', '']],
					styles: ['font-size: 0.88rem', 'margin: 0.4rem 0 0'],
				})}
			>
				<p class="work-card-subtitle" style="margin: 0;">A shared-backend architecture for MCP server registration and discovery.</p>
				<p class="principle-card-meta">.work-card-subtitle, 0.85rem, muted</p>
			</div>
		</div>

		<h2 class="section-title">Geometric Patterns</h2>
		<p class="principle-card-meta">Each case study gets a hand-drawn SVG pattern instead of a screenshot — no stock photography, no placeholder UI.</p>
		<div class="pattern-gallery">
			{work.map((project) => (
				<div
					class="pattern-gallery-item"
					data-annotation={JSON.stringify({
						name: `${project.data.name} pattern`,
						component: `<PatternSVG pattern="${project.data.pattern}" />`,
						vars: [['color', project.data.color]],
						styles: ['opacity: 0.7 (0.55 in night theme)'],
					})}
				>
					<div class="work-card-visual" style={`color: ${project.data.color}`}>
						<PatternSVG pattern={project.data.pattern} />
					</div>
					<p class="swatch-name">{project.data.pattern}</p>
					<p class="principle-card-meta">{project.data.name}</p>
				</div>
			))}
		</div>

		<h2 class="section-title">Components</h2>

		<div class="showcase-samples">
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Tag pill',
					component: '<span class="tag-pill" />',
					vars: [['--accent-indigo', '']],
					styles: ['font-size: 0.7rem', 'text-transform: uppercase', 'letter-spacing: 0.08em', 'background: rgba(56, 43, 95, 0.08)', 'border-radius: 2px'],
				})}
			>
				<div class="tag-list">
					{xdLibrary.data.tags?.map((tag) => <span class="tag-pill">{tag}</span>)}
				</div>
				<p class="principle-card-meta">.tag-pill</p>
			</div>

			<div class="showcase-sample">
				<div class="principle-card" style="max-width: 360px;">
					<h3>Systems Thinking, Human Outcomes</h3>
					<p>
						The best system is invisible; it just works. I design for the architecture
						underneath, not just the screen on top.
					</p>
				</div>
				<p class="principle-card-meta">.principle-card</p>
			</div>

			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Case study card (supporting)',
					component: '<a class="work-card work-card-supporting" />',
					vars: [['--card-color', xdLibrary.data.color], ['--border', '']],
					styles: ['padding: 1.25rem 1.25rem 1.5rem', 'border-radius: 8px', '::before: 4px top accent bar in --card-color'],
				})}
			>
				<a class="work-card work-card-supporting" href={withBase(`work/${xdLibrary.id}`)} style={`max-width: 320px; display: block; --card-color: ${xdLibrary.data.color}`}>
					<h3>{xdLibrary.data.name}</h3>
					<p class="work-card-subtitle">{xdLibrary.data.subtitle}</p>
				</a>
				<p class="principle-card-meta">.work-card-supporting</p>
			</div>

			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Metric callout',
					component: '<div class="metric-callout" />',
					vars: [['--ink', ''], ['--muted', '']],
					styles: ['font-size: clamp(1.75rem, 5vw, 2.75rem)', 'font-variant-numeric: tabular-nums', 'letter-spacing: -0.02em', 'font-weight: 600'],
				})}
			>
				<div class="metric-callout">
					{xdMetric.staticPrefix && <span class="metric-static">{xdMetric.staticPrefix}</span>}
					<span class="metric-value">{xdMetric.animPrefix}{xdMetric.comma ? xdMetric.end.toLocaleString() : xdMetric.end}{xdMetric.animSuffix}</span>
					<span class="metric-label">{xdLibrary.data.metricLabel}</span>
				</div>
				<p class="principle-card-meta">.metric-callout</p>
			</div>

			<div class="showcase-sample">
				{xdLibrary.data.snapshot && (
					<dl class="case-study-snapshot" style="margin: 0;">
						<div><dt>Role</dt><dd>{xdLibrary.data.snapshot.role}</dd></div>
						<div><dt>Timeline</dt><dd>{xdLibrary.data.snapshot.timeline}</dd></div>
						<div><dt>Tools</dt><dd>{xdLibrary.data.snapshot.tools}</dd></div>
						<div><dt>Team</dt><dd>{xdLibrary.data.snapshot.team}</dd></div>
					</dl>
				)}
				<p class="principle-card-meta">.case-study-snapshot</p>
			</div>
		</div>

		<h2 class="section-title">Site Chrome</h2>
		<p class="principle-card-meta">Inert replicas of the header, footer, and palette chrome — rendered here so the live site's nav, theme toggle, and command palette stay untouched.</p>
		<div class="showcase-samples">
			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: '⌘K palette trigger badge',
					component: '<button class="cmdk-hint" />',
					vars: [['--border', ''], ['--muted', ''], ['--accent-indigo', '']],
					styles: ['border-radius: 999px', 'padding: 0.3rem 0.65rem', 'hover: border + text color shift to --accent-indigo, cmdk-pulse 0.6s'],
				})}
			>
				<button class="cmdk-hint ds-inert" type="button" tabindex="-1" aria-hidden="true">
					<span class="cmdk-hint-kbd"><kbd>&#8984;</kbd><kbd>K</kbd></span>
					<svg class="cmdk-hint-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="11" cy="11" r="7"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
				</button>
				<p class="principle-card-meta">.cmdk-hint (inert replica)</p>
			</div>

			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Dark mode toggle',
					component: '<button class="theme-toggle" />',
					vars: [['--ink', '']],
					styles: ['width: 28px', 'height: 28px', 'swaps sun/moon SVG via [data-theme="night"] selector'],
				})}
			>
				<button class="theme-toggle ds-inert" type="button" tabindex="-1" aria-hidden="true">
					<svg class="theme-toggle-icon theme-toggle-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="4"></circle>
						<line x1="12" y1="2" x2="12" y2="4"></line>
						<line x1="12" y1="20" x2="12" y2="22"></line>
						<line x1="4.93" y1="4.93" x2="6.34" y2="6.34"></line>
						<line x1="17.66" y1="17.66" x2="19.07" y2="19.07"></line>
						<line x1="2" y1="12" x2="4" y2="12"></line>
						<line x1="20" y1="12" x2="22" y2="12"></line>
						<line x1="4.93" y1="19.07" x2="6.34" y2="17.66"></line>
						<line x1="17.66" y1="6.34" x2="19.07" y2="4.93"></line>
					</svg>
					<svg class="theme-toggle-icon theme-toggle-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
					</svg>
				</button>
				<p class="principle-card-meta">.theme-toggle (inert replica)</p>
			</div>

			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Navigation logo mark',
					component: '<svg class="brand-mark" />',
					vars: [['--muted', ''], ['--ink', ''], ['--accent', '']],
					styles: ['width: 28px', 'height: 28px', 'hand-plotted node graph echoing the case-study pattern motif'],
				})}
			>
				<svg class="brand-mark" viewBox="2 -1 20 20" aria-hidden="true">
					<line x1="4" y1="14" x2="9" y2="5" stroke="var(--muted)" stroke-width="1" stroke-linecap="round" />
					<line x1="9" y1="5" x2="14" y2="9" stroke="var(--muted)" stroke-width="1" stroke-linecap="round" />
					<circle cx="4" cy="14" r="1.3" fill="var(--ink)" />
					<circle cx="9" cy="5" r="1.5" fill="var(--ink)" />
					<circle cx="14" cy="9" r="2" fill="var(--accent)" />
					<circle cx="19" cy="4" r="1.1" fill="var(--ink)" />
					<circle cx="20.5" cy="14" r="0.8" fill="var(--ink)" />
				</svg>
				<p class="principle-card-meta">.brand-mark</p>
			</div>

			<div
				class="showcase-sample"
				data-annotation={JSON.stringify({
					name: 'Footer star field',
					component: '.site-footer::before',
					vars: [],
					styles: [
						'A 2x2px pseudo-element with no visible size of its own',
						'box-shadow draws ten extra "stars" at fixed offsets, each its own shadow layer',
						'--star-max custom property sets max opacity: 0.15 by day, 1 at night',
						'@keyframes site-footer-twinkle animates opacity between 40%–100% of --star-max',
					],
				})}
			>
				<div class="ds-star-demo" aria-hidden="true"></div>
				<p class="principle-card-meta">.site-footer::before (demo)</p>
			</div>
		</div>

		<h2 class="section-title">Motion &amp; Micro-interactions</h2>
		<p class="principle-card-meta">
			A written inventory, not live demos — these are ambient details meant to be noticed in
			context, not staged out of it. All of it respects <code>prefers-reduced-motion</code>.
		</p>
		<ul class="motion-inventory">
			<li><strong>Cursor lens</strong> — soft radial gradient follows the cursor with an 80ms lag</li>
			<li><strong>Aperture click</strong> — hexagonal iris SVG flashes at the click point, 180ms</li>
			<li><strong>Link underlines</strong> — draw left to right on hover, 150ms</li>
			<li><strong>Metric counters</strong> — count up on first scroll into view, 600ms ease-out</li>
			<li><strong>Focus ring</strong> — single pulse on keyboard focus, 300ms</li>
			<li><strong>Film grain</strong> — fades in on photo hover, 200ms</li>
			<li><strong>Filmstrip scroll bar</strong> — fills as the page scrolls</li>
			<li><strong>Star field</strong> — slow CSS twinkle in the footer</li>
			<li><strong>Milky Way parallax</strong> — 4–6px shift against cursor movement on the About page</li>
		</ul>
	</div>
</Base>

<style is:global>
	/* This page's own annotation-layer + star-demo styles. Marked is:global
	   because the tooltip and trigger elements are created at runtime via
	   document.createElement (not rendered by Astro), so they never receive
	   the scoped data-astro-cid attribute a normal <style> block relies on.
	   Every selector below is uniquely prefixed (.ds-*) so this can't leak
	   into or collide with the real site chrome's styling. */
	.ds-star-demo {
		position: relative;
		overflow: hidden;
		width: 200px;
		height: 40px;
		border-radius: 4px;
		background: var(--ink);
	}

	.ds-star-demo::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 2px;
		height: 2px;
		pointer-events: none;
		--star-max: 0.15;
		box-shadow:
			10px 8px 0 1px rgba(255, 255, 255, 0.4),
			28px 22px 0 0px rgba(255, 255, 255, 0.3),
			52px 6px 0 1px rgba(255, 255, 255, 0.5),
			70px 28px 0 0px rgba(255, 255, 255, 0.25),
			95px 12px 0 1px rgba(255, 255, 255, 0.4),
			115px 32px 0 0px rgba(255, 255, 255, 0.3),
			140px 5px 0 1px rgba(255, 255, 255, 0.45),
			160px 24px 0 0px rgba(255, 255, 255, 0.35),
			180px 14px 0 1px rgba(255, 255, 255, 0.3);
		animation: site-footer-twinkle 4s ease-in-out infinite alternate;
	}

	[data-theme='night'] .ds-star-demo::before {
		--star-max: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.ds-star-demo::before {
			animation: none;
			opacity: var(--star-max);
		}
	}

	/* inert chrome replicas shouldn't look interactive or be reachable by
	   keyboard/AT — they're visual references only. */
	.ds-inert {
		cursor: default;
		pointer-events: none;
	}

	/* annotation layer */
	[data-annotation] {
		position: relative;
	}

	.ds-annotation-trigger {
		position: absolute;
		top: 0.35rem;
		right: 0.35rem;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: 4px;
		background: var(--paper);
		color: var(--accent-indigo);
		font-family: var(--mono);
		font-size: 0.65rem;
		line-height: 1;
		cursor: pointer;
		opacity: 0;
		transition: opacity 0.12s ease;
	}

	[data-annotation]:hover .ds-annotation-trigger,
	[data-annotation]:focus-within .ds-annotation-trigger,
	.ds-annotation-trigger.is-touch-visible {
		opacity: 1;
	}

	.ds-annotation-trigger:focus-visible {
		opacity: 1;
	}

	.ds-tooltip {
		position: fixed;
		z-index: 1000;
		max-width: 320px;
		padding: 0.9rem 1rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--paper);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
		font-family: var(--mono);
		font-size: 0.78rem;
		line-height: 1.5;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.12s ease;
	}

	.ds-tooltip.is-open {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	.ds-tooltip-name {
		margin: 0 0 0.5rem;
		font-weight: 600;
		color: var(--ink);
	}

	.ds-tooltip-component {
		margin: 0 0 0.6rem;
		color: var(--accent-indigo);
		word-break: break-word;
	}

	.ds-tooltip-vars,
	.ds-tooltip-styles {
		margin: 0 0 0.6rem;
		padding: 0.6rem 0;
		border-top: 1px solid var(--border);
		list-style: none;
	}

	.ds-tooltip-styles {
		margin-bottom: 0;
	}

	.ds-tooltip-vars li,
	.ds-tooltip-styles li {
		display: flex;
		gap: 0.6rem;
		color: var(--muted);
		word-break: break-word;
	}

	.ds-tooltip-vars li + li,
	.ds-tooltip-styles li + li {
		margin-top: 0.3rem;
	}

	.ds-tooltip-vars li span:first-child {
		flex-shrink: 0;
		color: var(--ink);
	}
</style>

<script is:inline>
	function updateTokenValues() {
		const styles = getComputedStyle(document.documentElement);
		document.querySelectorAll('[data-token-value]').forEach((el) => {
			const name = el.dataset.tokenValue;
			el.textContent = styles.getPropertyValue(`--${name}`).trim();
		});
	}

	document.addEventListener('astro:page-load', updateTokenValues);

	const w = window;
	if (!w.__designSystemTokensBound) {
		new MutationObserver(updateTokenValues).observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['data-theme'],
		});
		w.__designSystemTokensBound = true;
	}
</script>

<script is:inline>
	window.dsAnnotations =
		window.dsAnnotations ||
		{
			isTouch: window.matchMedia('(hover: none)').matches,
			HOVER_DELAY: 500,
			tooltip: null,
			openTrigger: null,
			hoverTimer: null,
		};
	var dsAnnotations = window.dsAnnotations;

	function dsGetTooltip() {
		if (!dsAnnotations.tooltip || !document.body.contains(dsAnnotations.tooltip)) {
			const el = document.createElement('div');
			el.className = 'ds-tooltip';
			el.setAttribute('role', 'tooltip');
			document.body.appendChild(el);
			dsAnnotations.tooltip = el;
		}
		return dsAnnotations.tooltip;
	}

	function dsEscapeHtml(str) {
		const div = document.createElement('div');
		div.textContent = String(str);
		return div.innerHTML;
	}

	function dsRenderTooltip(data) {
		const tooltip = dsGetTooltip();
		const computed = getComputedStyle(document.documentElement);

		const varsHtml = (data.vars || [])
			.map(([name, fallback]) => {
				const isCssVar = name.startsWith('--');
				const value = isCssVar ? computed.getPropertyValue(name).trim() : fallback || '';
				return `<li><span>${dsEscapeHtml(name)}</span><span>${dsEscapeHtml(value)}</span></li>`;
			})
			.join('');

		const stylesHtml = (data.styles || []).map((s) => `<li><span>${dsEscapeHtml(s)}</span></li>`).join('');

		tooltip.innerHTML = `
			<p class="ds-tooltip-name">&lt; &gt; ${dsEscapeHtml(data.name || '')}</p>
			${data.component ? `<p class="ds-tooltip-component">Component: ${dsEscapeHtml(data.component)}</p>` : ''}
			${varsHtml ? `<ul class="ds-tooltip-vars">${varsHtml}</ul>` : ''}
			${stylesHtml ? `<ul class="ds-tooltip-styles">${stylesHtml}</ul>` : ''}
		`;
	}

	function dsPositionTooltip(trigger) {
		const tooltip = dsGetTooltip();
		const rect = trigger.getBoundingClientRect();
		const tooltipRect = tooltip.getBoundingClientRect();
		const margin = 8;

		let left = rect.right - tooltipRect.width;
		left = Math.max(margin, Math.min(left, window.innerWidth - tooltipRect.width - margin));

		let top = rect.bottom + margin;
		const fitsBelow = top + tooltipRect.height <= window.innerHeight - margin;

		if (!fitsBelow && !dsAnnotations.isTouch) {
			const above = rect.top - tooltipRect.height - margin;
			if (above >= margin) {
				top = above;
			}
		}

		tooltip.style.left = `${left}px`;
		tooltip.style.top = `${top}px`;
	}

	function dsOpenTooltip(trigger, data) {
		dsRenderTooltip(data);
		dsGetTooltip().classList.add('is-open');
		dsPositionTooltip(trigger);
		dsAnnotations.openTrigger = trigger;
	}

	function dsCloseTooltip() {
		const tooltip = dsGetTooltip();
		tooltip.classList.remove('is-open');
		dsAnnotations.openTrigger = null;
		if (dsAnnotations.hoverTimer) {
			clearTimeout(dsAnnotations.hoverTimer);
			dsAnnotations.hoverTimer = null;
		}
	}

	function initAnnotationLayer() {
		dsGetTooltip();

		document.querySelectorAll('[data-annotation]').forEach((el) => {
			if (el.dataset.annotationBound) return;
			el.dataset.annotationBound = 'true';

			let data;
			try {
				data = JSON.parse(el.dataset.annotation);
			} catch {
				return;
			}

			const trigger = document.createElement('button');
			trigger.type = 'button';
			trigger.className = 'ds-annotation-trigger';
			if (dsAnnotations.isTouch) {
				// No real hover state on touch — keep the trigger visible so
				// there's something to tap in the first place.
				trigger.classList.add('is-touch-visible');
			}
			trigger.setAttribute('aria-label', `Show annotation for ${data.name || 'component'}`);
			trigger.textContent = '< >';
			el.appendChild(trigger);

			// Clicking a <button> focuses it natively before the click event
			// fires. Track whether the upcoming focus came from a pointer
			// press so the click handler's toggle logic is the single source
			// of truth for pointer interactions, while keyboard focus (tab)
			// still opens the tooltip on its own.
			let pointerFocusPending = false;
			trigger.addEventListener('pointerdown', () => {
				pointerFocusPending = true;
			});

			function toggle() {
				if (dsAnnotations.openTrigger === trigger && dsGetTooltip().classList.contains('is-open')) {
					dsCloseTooltip();
				} else {
					dsOpenTooltip(trigger, data);
				}
			}

			trigger.addEventListener('click', (e) => {
				e.stopPropagation();
				toggle();
			});

			if (dsAnnotations.isTouch) {
				return;
			}

			el.addEventListener('mouseenter', () => {
				if (dsAnnotations.hoverTimer) clearTimeout(dsAnnotations.hoverTimer);
				dsAnnotations.hoverTimer = setTimeout(() => dsOpenTooltip(trigger, data), dsAnnotations.HOVER_DELAY);
			});

			el.addEventListener('mouseleave', () => {
				if (dsAnnotations.hoverTimer) {
					clearTimeout(dsAnnotations.hoverTimer);
					dsAnnotations.hoverTimer = null;
				}
				if (dsAnnotations.openTrigger === trigger) dsCloseTooltip();
			});

			trigger.addEventListener('focus', () => {
				if (pointerFocusPending) {
					pointerFocusPending = false;
					return;
				}
				dsOpenTooltip(trigger, data);
			});
			trigger.addEventListener('blur', () => {
				pointerFocusPending = false;
				if (dsAnnotations.openTrigger === trigger) dsCloseTooltip();
			});
		});

		const w = window;
		if (!w.__designSystemAnnotationsGlobalBound) {
			document.addEventListener('click', (e) => {
				if (!dsAnnotations.openTrigger) return;
				if (e.target.closest('.ds-annotation-trigger') || e.target.closest('.ds-tooltip')) return;
				dsCloseTooltip();
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && dsAnnotations.openTrigger) dsCloseTooltip();
			});

			window.addEventListener(
				'scroll',
				() => {
					if (dsAnnotations.openTrigger) dsCloseTooltip();
				},
				{ passive: true }
			);

			w.__designSystemAnnotationsGlobalBound = true;
		}
	}

	document.addEventListener('astro:page-load', initAnnotationLayer);
</script>
