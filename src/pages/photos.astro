---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/url';

const photos = [
	{ src: 'moonrise.jpg', alt: 'Full moon rising through trees over a neighborhood', label: 'Moonrise' },
	{ src: 'milky-way.jpg', alt: 'The Milky Way over open sky', label: 'Milky Way' },
	{ src: 'cherry-blossoms.jpg', alt: 'Cherry blossoms in bloom', label: 'Cherry Blossoms' },
	{ src: 'fall-foliage.jpg', alt: 'Autumn trees in fall foliage', label: 'Fall Foliage' },
	{ src: 'azaleas.jpg', alt: 'Pink azalea blossoms in close-up', label: 'Azaleas' },
	{ src: 'dsc02733.jpg', alt: 'Portrait of Christopher Rangel, laughing', label: 'Portrait' },
	{ src: 'laguna-sunset.jpg', alt: 'Sunset over the ocean', label: 'Sunset' },
	{ src: 'plants.jpg', alt: 'Close-up of leaves with dew drops', label: 'Leaves' },
];
---

<Base title="Photos — Christopher Rangel" description="Photography by Christopher Rangel">
	<div class="container">
		<section class="hero">
			<h1>Photos</h1>
			<p>Patterns found outside the screen.</p>
		</section>
		<div class="photos-grid">
			{photos.map((photo, i) => (
				<button type="button" class="photo-tile" data-index={i} aria-label={`View ${photo.label} full screen`}>
					<img src={withBase(`images/${photo.src}`)} alt={photo.alt} loading="lazy" />
					<span class="photo-tile-label">{photo.label}</span>
				</button>
			))}
		</div>
	</div>

	<div class="photos-lightbox" id="photos-lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
		<button type="button" class="photos-lightbox-close" aria-label="Close">&times;</button>
		<button type="button" class="photos-lightbox-prev" aria-label="Previous photo">&larr;</button>
		<img class="photos-lightbox-img" alt="" />
		<p class="photos-lightbox-label"></p>
		<button type="button" class="photos-lightbox-next" aria-label="Next photo">&rarr;</button>
	</div>
</Base>

<script>
	interface Photo {
		src: string;
		alt: string;
		label: string;
	}

	function getPhotos(): Photo[] {
		return Array.from(document.querySelectorAll<HTMLButtonElement>('.photo-tile')).map((tile) => {
			const img = tile.querySelector('img');
			return { src: img?.src ?? '', alt: img?.alt ?? '', label: tile.querySelector('.photo-tile-label')?.textContent ?? '' };
		});
	}

	let currentIndex = 0;

	function lightbox() {
		return document.getElementById('photos-lightbox');
	}

	function show(index: number) {
		const photos = getPhotos();
		if (photos.length === 0) return;
		currentIndex = (index + photos.length) % photos.length;
		const photo = photos[currentIndex];
		const box = lightbox();
		if (!box) return;
		const img = box.querySelector('img');
		const label = box.querySelector('.photos-lightbox-label');
		if (img) {
			img.src = photo.src;
			img.alt = photo.alt;
		}
		if (label) label.textContent = photo.label;
	}

	function open(index: number) {
		show(index);
		lightbox()?.classList.add('open');
	}

	function close() {
		lightbox()?.classList.remove('open');
	}

	function isOpen() {
		return lightbox()?.classList.contains('open') ?? false;
	}

	function onClick(e: MouseEvent) {
		const target = e.target as Element;

		const tile = target.closest<HTMLButtonElement>('.photo-tile');
		if (tile) {
			open(Number(tile.dataset.index ?? 0));
			return;
		}

		if (!isOpen()) return;

		if (target.closest('.photos-lightbox-close')) {
			close();
		} else if (target.closest('.photos-lightbox-prev')) {
			show(currentIndex - 1);
		} else if (target.closest('.photos-lightbox-next')) {
			show(currentIndex + 1);
		} else if (target === lightbox()) {
			close();
		}
	}

	function onKeydown(e: KeyboardEvent) {
		if (!isOpen()) return;
		if (e.key === 'Escape') close();
		else if (e.key === 'ArrowLeft') show(currentIndex - 1);
		else if (e.key === 'ArrowRight') show(currentIndex + 1);
	}

	const w = window as typeof window & { __photosLightboxBound?: boolean };
	if (!w.__photosLightboxBound) {
		document.addEventListener('click', onClick);
		document.addEventListener('keydown', onKeydown);
		w.__photosLightboxBound = true;
	}
</script>
